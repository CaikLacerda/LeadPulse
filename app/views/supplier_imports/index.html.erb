<%# app/views/supplier_imports/index.html.erb %>

<div data-controller="import-modal"
     data-import-modal-default-label-value="<%= I18n.t('supplier_imports.modal.upload.label') %>"
     data-import-modal-selected-label-template-value="<%= I18n.t('supplier_imports.modal.upload.selected', name: '%{name}') %>"
     data-import-modal-cadastral-helper-value="<%= I18n.t('supplier_imports.modal.upload.cadastral_helper') %>"
     data-import-modal-supplier-helper-value="<%= I18n.t('supplier_imports.modal.upload.supplier_helper') %>"
     data-import-modal-cadastral-submit-label-value="<%= I18n.t('supplier_imports.modal.submit.cadastral') %>"
     data-import-modal-supplier-submit-label-value="<%= I18n.t('supplier_imports.modal.submit.supplier') %>"
     data-import-modal-preview-url-value="<%= preview_import_supplier_imports_path %>"
     data-import-modal-preview-loading-label-value="<%= I18n.t('supplier_imports.modal.preview.loading') %>"
     data-import-modal-preview-generic-error-label-value="<%= I18n.t('supplier_imports.modal.preview.generic_error') %>"
     data-import-modal-preview-ready-label-value="<%= I18n.t('supplier_imports.modal.preview.ready') %>"
     data-import-modal-preview-blocked-label-value="<%= I18n.t('supplier_imports.modal.preview.blocked') %>"
     data-import-modal-preview-total-label-value="<%= I18n.t('supplier_imports.modal.preview.summary.total_rows') %>"
     data-import-modal-preview-valid-label-value="<%= I18n.t('supplier_imports.modal.preview.summary.valid_rows') %>"
     data-import-modal-preview-invalid-label-value="<%= I18n.t('supplier_imports.modal.preview.summary.invalid_rows') %>"
     data-import-modal-preview-import-status-label-value="<%= I18n.t('supplier_imports.modal.preview.summary.import_status') %>"
     data-import-modal-preview-no-invalid-rows-label-value="<%= I18n.t('supplier_imports.modal.preview.no_invalid_rows') %>">
<div class="settings-shell min-h-screen px-5 pb-16 pt-28 sm:px-8 lg:px-10">
  <div class="home-orb home-orb--blue -left-20 top-24 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-orb home-orb--orange right-[-70px] top-12 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-bolt left-[7%] top-36 hidden h-24 w-14 lg:block"></div>
  <div class="home-bolt home-bolt--soft right-[12%] top-24 hidden h-20 w-12 lg:block"></div>

  <div class="workspace-content mx-auto max-w-7xl">
    <section class="mb-8 flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
      <div class="max-w-3xl">
        <p class="text-xs font-extrabold uppercase tracking-[0.28em] text-blue-700"><%= t('.kicker') %></p>
        <h1 class="mt-3 text-3xl font-black tracking-tight text-slate-950 sm:text-4xl"><%= t('.title') %></h1>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
          <%= t('.description') %>
        </p>
      </div>

      <div class="flex flex-wrap gap-2" data-tutorial-id="imports-create">
        <button type="button"
                data-action="import-modal#open"
                class="settings-submit settings-submit--accent">
          <%= t('.new_batch') %>
        </button>
      </div>
    </section>

    <%= form_with url: supplier_imports_path, method: :get, local: true do |f| %>
      <div class="workspace-toolbar mb-6" data-tutorial-id="imports-filters">
        <div class="grid gap-3 xl:grid-cols-[minmax(0,1.35fr)_190px_190px_190px_auto]">
          <%= f.text_field :q, value: params[:q],
              placeholder: t('.filters.query'),
              class: 'settings-input' %>

          <%= f.select :periodo,
              [[t('.filters.any_date'), ''], [t('.filters.last_7_days'), '7d'], [t('.filters.last_month'), '30d'], [t('.filters.last_year'), '1y']],
              { selected: params[:periodo] },
              class: 'settings-input appearance-none' %>

          <%= f.select :status,
              [[t('.filters.all_statuses'), 'todos'], [local_status_label(SupplierImport::LOCAL_STATUS_PENDING), 'pendente'], [local_status_label(SupplierImport::LOCAL_STATUS_PROCESSING), 'processando'], [local_status_label(SupplierImport::LOCAL_STATUS_COMPLETED), 'concluido'], [local_status_label(SupplierImport::LOCAL_STATUS_ERROR), 'erro']],
              { selected: params[:status] },
              class: 'settings-input appearance-none' %>

          <%= f.select :workflow_kind,
              [[t('.filters.all_types'), 'todos'], [t('.filters.cadastral'), SupplierImport::WORKFLOW_KIND_CADASTRAL], [t('.filters.supplier'), SupplierImport::WORKFLOW_KIND_SUPPLIER]],
              { selected: params[:workflow_kind] },
              class: 'settings-input appearance-none' %>

          <div class="flex gap-2">
            <%= link_to supplier_imports_path,
                class: 'workspace-button workspace-button--secondary' do %>
              <%= t('.filters.clear') %>
            <% end %>

            <button type="submit"
                    class="workspace-button workspace-button--primary">
              <%= t('.filters.submit') %>
            </button>
          </div>
        </div>
      </div>
    <% end %>

    <div class="workspace-surface" data-tutorial-id="imports-results">
      <div class="workspace-surface-header">
        <p class="workspace-surface-title"><%= t('.table.title') %></p>
        <p class="workspace-surface-meta"><%= t('.table.count', count: @imports_total_count) %></p>
      </div>

      <div class="overflow-x-auto overflow-y-visible">
        <table class="workspace-table">
          <thead>
            <tr>
              <th><%= t('.table.headers.batch') %></th>
              <th><%= t('.table.headers.date') %></th>
              <th><%= t('.table.headers.source') %></th>
              <th><%= t('.table.headers.type') %></th>
              <th><%= t('.table.headers.total') %></th>
              <th><%= t('.table.headers.valid') %></th>
              <th><%= t('.table.headers.invalid') %></th>
              <th><%= t('.table.headers.status') %></th>
              <th><%= t('.table.headers.actions') %></th>
            </tr>
          </thead>

          <tbody>
            <% if @imports.any? %>
              <% @imports.each do |import| %>
                <tr>
                  <td>
                    <span class="workspace-compact-code"><%= import.display_code %></span>
                  </td>

                  <td>
                    <div class="font-medium text-slate-800"><%= workspace_date(import.created_at) %></div>
                    <div class="mt-0.5 text-[11px] text-slate-400"><%= workspace_time(import.created_at) %></div>
                  </td>

                  <td class="font-medium text-slate-700"><%= import.source_label %></td>
                  <td class="font-medium text-slate-700"><%= import.workflow_kind_label %></td>
                  <td class="font-medium text-slate-700"><%= import.total_rows %></td>
                  <td class="font-semibold text-emerald-600"><%= import.valid_rows %></td>
                  <td class="font-semibold text-rose-500"><%= import.invalid_rows %></td>

                  <td>
                    <%= workspace_status_tag(import.status) %>
                  </td>

                  <td class="whitespace-nowrap">
                    <details data-controller="action-menu" class="relative inline-block">
                      <summary class="workspace-summary-button">
                        <%= t('.actions.label') %>
                      </summary>

                      <div class="workspace-menu absolute right-0 top-[calc(100%+0.25rem)] z-20 w-36 p-1">
                        <% if import.errored? %>
                          <%= button_to start_validation_supplier_import_path(import),
                              method: :post,
                              class: 'workspace-menu-item' do %>
                            <%= t('.actions.restart') %>
                          <% end %>
                          <%= button_to supplier_import_path(import),
                              method: :delete,
                              form: { data: { turbo_confirm: t('.confirm.message'), turbo_confirm_title: t('.confirm.title'), turbo_confirm_confirm_label: t('.confirm.confirm'), turbo_confirm_cancel_label: t('.confirm.cancel') } },
                              class: 'workspace-menu-item workspace-menu-item--danger' do %>
                            <%= t('.actions.delete') %>
                          <% end %>
                        <% else %>
                          <% if import.pending? %>
                            <%= button_to start_validation_supplier_import_path(import),
                                method: :post,
                                class: 'workspace-menu-item' do %>
                              <%= t('.actions.start') %>
                            <% end %>
                          <% end %>

                          <% if import.syncable? %>
                            <%= button_to sync_status_supplier_import_path(import),
                                method: :post,
                                class: 'workspace-menu-item' do %>
                              <%= t('.actions.sync') %>
                            <% end %>
                          <% end %>

                          <% if import.ready_to_export? %>
                            <%= link_to export_result_supplier_import_path(import),
                                data: { turbo: false },
                                class: 'workspace-menu-item' do %>
                              <%= t('.actions.export') %>
                            <% end %>
                          <% end %>

                          <% if import.destroyable? %>
                            <%= button_to supplier_import_path(import),
                                method: :delete,
                                form: { data: { turbo_confirm: t('.confirm.message'), turbo_confirm_title: t('.confirm.title'), turbo_confirm_confirm_label: t('.confirm.confirm'), turbo_confirm_cancel_label: t('.confirm.cancel') } },
                                class: 'workspace-menu-item workspace-menu-item--danger' do %>
                              <%= t('.actions.delete') %>
                            <% end %>
                          <% end %>
                        <% end %>
                      </div>
                    </details>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="9" class="px-4 py-12 text-center text-sm text-slate-500">
                  <%= t('.table.empty') %>
                  <button type="button"
                          data-action="import-modal#open"
                          class="workspace-button workspace-button--primary ml-2">
                    <%= t('supplier_imports.messages.import_ready') %>
                  </button>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%= render 'shared/pagination', current_page: @imports_page, total_pages: @imports_total_pages %>
    </div>
  </div>
</div>

<%= render 'import_modal' %>
<%= render 'shared/workspace_tutorial', steps: workspace_tutorial_steps(:supplier_imports) %>
</div>
