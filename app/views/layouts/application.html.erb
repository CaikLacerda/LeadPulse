<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || t('shared.app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Leadpulse">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-white text-gray-900 <%= 'app-shell--authenticated' if user_signed_in? %>">
    <%= render 'shared/site_header', auth_page: false %>
    <main class="pt-16 md:pt-20">
      <% visible_flashes = controller_name == 'platform_settings' ? {} : flash.to_hash.except('generated_api_token').select { |_, message| message.present? } %>
      <% if visible_flashes.any? %>
        <div class="app-flash-overlay px-4 sm:px-6 lg:px-8">
          <div class="app-flash-stack">
            <% visible_flashes.each do |type, message| %>
              <% variant = %w[alert error].include?(type.to_s) ? 'alert' : 'notice' %>
              <% label = t("shared.flash.#{variant}") %>
              <div class="app-flash app-flash--<%= variant %>"
                   role="<%= variant == 'alert' ? 'alert' : 'status' %>"
                   data-controller="flash"
                   data-action="click->flash#dismiss"
                   data-flash-delay-value="5000">
                <span class="app-flash__label"><%= label %></span>
                <span class="app-flash__message"><%= message %></span>
                <span class="app-flash__bolt" aria-hidden="true">⚡</span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
