<%# app/views/pages/home.html.erb %>

<!-- HERO -->
<section id="inicio" class="min-h-screen flex items-center justify-center text-center px-8 pt-24 pb-16 bg-gray-50">
  <div class="max-w-2xl">
    <h1 class="text-5xl md:text-6xl font-black leading-tight tracking-tight text-gray-900">
      Sua base de dados<br>
      <span class="text-blue-600">sempre pulsando.</span>
    </h1>
    <p class="mt-5 text-lg text-gray-500 leading-relaxed">
      Validação inteligente de fornecedores com IA. Limpamos listas obsoletas
      em minutos através de chamadas automatizadas.
    </p>
    <div class="flex gap-4 justify-center mt-9 flex-wrap">
      <%= link_to "Testar Gratuitamente", new_user_registration_path,
          class: "px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold text-sm hover:bg-blue-700 transition-all hover:-translate-y-0.5 shadow-md" %>
      <a href="#recursos"
         class="px-6 py-3 rounded-xl border-2 border-orange-400 text-orange-500 font-semibold text-sm hover:bg-orange-500 hover:text-white transition-all">
        Como Funciona
      </a>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="recursos" class="bg-slate-100 py-20 px-8">
  <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">

    <!-- Card 1 -->
    <div class="bg-white rounded-2xl p-9 shadow-sm text-center hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
      <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5">🔍</div>
      <h3 class="text-lg font-bold text-blue-600 mb-2">Escaneamento</h3>
      <p class="text-sm text-gray-500 leading-relaxed">Analise e valide automaticamente sua lista de fornecedores com precisão e rapidez.</p>
    </div>

    <!-- Card 2 -->
    <div class="bg-white rounded-2xl p-9 shadow-sm text-center hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
      <div class="w-16 h-16 bg-orange-50 rounded-2xl flex items-center justify-content text-3xl mx-auto mb-5 flex items-center justify-center">🤖</div>
      <h3 class="text-lg font-bold text-orange-500 mb-2">Auditoria por Voz</h3>
      <p class="text-sm text-gray-500 leading-relaxed">IA realiza chamadas automatizadas para confirmar dados de contato em tempo real.</p>
    </div>

    <!-- Card 3 -->
    <div class="bg-white rounded-2xl p-9 shadow-sm text-center hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
      <div class="w-16 h-16 bg-purple-50 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5">📊</div>
      <h3 class="text-lg font-bold text-purple-600 mb-2">Enriquecimento</h3>
      <p class="text-sm text-gray-500 leading-relaxed">Complemente e atualize os dados dos fornecedores com informações confiáveis e atuais.</p>
    </div>

  </div>
</section>
