<div class="settings-shell min-h-screen px-5 pb-16 pt-28 sm:px-8 lg:px-10">
  <div class="home-orb home-orb--blue -left-16 top-24 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-orb home-orb--orange right-[-60px] top-12 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-bolt left-[7%] top-36 hidden h-24 w-14 lg:block"></div>
  <div class="home-bolt home-bolt--soft right-[12%] top-24 hidden h-20 w-12 lg:block"></div>

  <div class="mx-auto max-w-5xl">
    <%= turbo_frame_tag 'platform_settings_content' do %>
      <section class="settings-page-intro mb-8">
        <p class="settings-panel-kicker">Integração</p>
        <h1 class="settings-panel-title">Empresa</h1>
        <div class="home-energy-line mt-4 h-[3px] w-28 rounded-full"></div>
      </section>

      <%= render 'nav' %>

      <div class="settings-panel p-6 sm:p-8 lg:p-10">
        <% settings_notice = flash[:notice].presence || flash.now[:notice].presence %>
        <% settings_alert = flash.now[:alert].presence || flash[:alert].presence %>

        <%= form_with model: current_user, url: company_platform_settings_path, method: :patch, local: true, class: 'space-y-8' do |f| %>
          <% if settings_notice.present? %>
            <div class="settings-feedback settings-feedback--notice"><%= settings_notice %></div>
          <% end %>

          <% if settings_alert.present? %>
            <div class="settings-feedback settings-feedback--alert"><%= settings_alert %></div>
          <% end %>

          <div class="settings-form-note">Campos marcados com * são obrigatórios para provisionar e salvar a empresa na API.</div>

          <div class="settings-form-grid grid gap-6 md:grid-cols-2" data-tutorial-id="company-fields">
            <div>
              <%= render 'field_label', form: f, field: :validation_company_name, text: 'Nome da empresa', help: 'Nome principal da conta dentro do LeadPulse e da integração com a API.', required: true %>
              <%= f.text_field :validation_company_name, value: current_user.validation_company_name_value, class: 'settings-input', required: true %>
            </div>

            <div>
              <%= render 'field_label', form: f, field: :validation_spoken_company_name, text: 'Nome falado pela IA', help: 'Como a IA deve citar sua empresa durante as ligações e confirmações.', required: true %>
              <%= f.text_field :validation_spoken_company_name, value: current_user.validation_spoken_company_name_value, class: 'settings-input', required: true %>
            </div>

            <div>
              <%= render 'field_label', form: f, field: :validation_owner_name, text: 'Responsável', help: 'Pessoa de referência para esta conta e para os ajustes operacionais.', required: true %>
              <%= f.text_field :validation_owner_name, value: current_user.validation_owner_name_value, class: 'settings-input', required: true %>
            </div>

            <div>
              <%= render 'field_label', form: f, field: :validation_owner_email, text: 'E-mail do responsável', help: 'Contato principal usado como referência administrativa desta integração.', required: true %>
              <%= f.email_field :validation_owner_email, value: current_user.validation_owner_email_value, class: 'settings-input', required: true %>
            </div>
          </div>

          <div class="settings-meta-card" data-tutorial-id="company-account">
            <span class="settings-meta-label">Conta na API</span>
            <span class="settings-meta-value"><%= current_user.validation_account_id.presence || 'ainda não provisionada' %></span>
          </div>

          <div class="flex justify-end">
            <%= f.submit 'Salvar empresa', class: 'settings-submit', data: { tutorial_id: 'company-submit' } %>
          </div>
        <% end %>
      </div>

      <%= render 'shared/workspace_tutorial', steps: workspace_tutorial_steps(:platform_settings_company) %>
    <% end %>
  </div>
</div>
