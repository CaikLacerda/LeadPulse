<div class="settings-shell min-h-screen px-5 pb-16 pt-28 sm:px-8 lg:px-10">
  <div class="home-orb home-orb--blue -left-20 top-24 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-orb home-orb--orange right-[-70px] top-12 h-56 w-56 sm:h-72 sm:w-72"></div>
  <div class="home-bolt left-[8%] top-32 hidden h-24 w-14 lg:block"></div>
  <div class="home-bolt home-bolt--soft right-[12%] top-24 hidden h-20 w-12 lg:block"></div>

  <div class="mx-auto max-w-5xl">
    <%= turbo_frame_tag 'platform_settings_content' do %>
      <% generated_api_token = flash[:generated_api_token].presence %>

      <section class="settings-page-intro mb-8">
        <p class="settings-panel-kicker">Integração</p>
        <h1 class="settings-panel-title">Token</h1>
        <div class="home-energy-line mt-4 h-[3px] w-28 rounded-full"></div>
      </section>

      <%= render 'nav' %>

      <div class="settings-panel p-6 sm:p-8 lg:p-10">
        <% settings_notice = flash[:notice].presence || flash.now[:notice].presence %>
        <% settings_alert = flash.now[:alert].presence || flash[:alert].presence %>

        <% if settings_notice.present? %>
          <div class="mb-6 settings-feedback settings-feedback--notice"><%= settings_notice %></div>
        <% end %>

        <% if settings_alert.present? %>
          <div class="mb-6 settings-feedback settings-feedback--alert"><%= settings_alert %></div>
        <% end %>

        <div class="mb-8 grid gap-4 md:grid-cols-3" data-tutorial-id="token-status">
          <div class="settings-data-card">
            <p class="settings-data-label">Conta na API</p>
            <p class="settings-data-value"><%= current_user.validation_account_id.presence || '—' %></p>
          </div>

          <div class="settings-data-card">
            <p class="settings-data-label">Prefixo</p>
            <p class="settings-data-value"><%= current_user.validation_api_token_prefix.presence || '—' %></p>
          </div>

          <div class="settings-data-card">
            <p class="settings-data-label">Criado em</p>
            <p class="settings-data-value"><%= workspace_datetime(current_user.validation_api_token_created_at) %></p>
          </div>
        </div>

        <% if generated_api_token.present? %>
          <div class="mb-8 rounded-[1.5rem] border border-orange-200 bg-orange-50/90 p-5 shadow-sm"
               data-controller="copy-to-clipboard"
               data-copy-to-clipboard-source-value="generated_api_token"
               data-copy-to-clipboard-default-text-value="<%= I18n.t('platform_settings.api_token.copy') %>"
               data-copy-to-clipboard-success-text-value="<%= I18n.t('platform_settings.api_token.copied') %>">
            <div class="settings-label-row">
              <label for="generated_api_token" class="settings-label settings-label--inline"><%= t('platform_settings.api_token.copy_now') %></label>
              <span class="settings-help-group" tabindex="0" aria-label="O token bruto aparece apenas uma vez após a geração. Se você perder, será necessário gerar um novo token.">
                <span class="settings-help-trigger" aria-hidden="true">?</span>
                <span class="settings-help-tooltip">O token bruto aparece apenas uma vez após a geração. Se você perder, será necessário gerar um novo token.</span>
              </span>
            </div>
            <input type="text" id="generated_api_token" value="<%= generated_api_token %>" readonly class="settings-input font-mono text-xs sm:text-sm">
            <p class="mt-3 text-sm leading-7 text-slate-600">
              Guarde este token em um local seguro. Depois desta tela, o LeadPulse mostra apenas o prefixo e mantém o valor protegido internamente.
            </p>
            <div class="mt-4 flex justify-end">
              <button type="button"
                      class="settings-submit settings-submit--accent"
                      data-copy-to-clipboard-target="button"
                      data-action="copy-to-clipboard#copy">
                <%= t('platform_settings.api_token.copy') %>
              </button>
            </div>
          </div>
        <% else %>
          <div class="mb-8">
            <div class="settings-label-row">
              <label class="settings-label settings-label--inline">Token atual</label>
              <span class="settings-help-group" tabindex="0" aria-label="O token não visível no painel. Gere um novo token se precisar copiar novamente.">
                <span class="settings-help-trigger" aria-hidden="true">?</span>
                <span class="settings-help-tooltip">O token não visível no painel. Gere um novo token se precisar copiar novamente.</span>
              </span>
            </div>
            <input type="text" value="<%= current_user.masked_validation_api_token %>" readonly class="settings-input text-sm">
          </div>
        <% end %>

        <%= form_with url: api_token_platform_settings_path, method: :post, local: true, class: 'space-y-6' do %>
          <div>
            <div class="settings-label-row">
              <label for="token_name" class="settings-label settings-label--inline">Nome do token</label>
              <span class="settings-help-group" tabindex="0" aria-label="Rótulo interno para identificar este token dentro da operação.">
                <span class="settings-help-trigger" aria-hidden="true">?</span>
                <span class="settings-help-tooltip">Rótulo interno para identificar este token dentro da operação.</span>
              </span>
            </div>
            <input type="text" id="token_name" name="token_name" value="leadpulse_web" class="settings-input">
          </div>

          <div class="rounded-[1.35rem] border border-slate-200 bg-slate-50 px-4 py-4 text-sm leading-7 text-slate-500">
            Ao gerar um novo token, o anterior é revogado automaticamente na API.
          </div>

          <div class="flex justify-end">
            <button type="submit" class="settings-submit settings-submit--accent" data-tutorial-id="token-submit">
              Gerar novo token
            </button>
          </div>
        <% end %>
      </div>

      <%= render 'shared/workspace_tutorial', steps: workspace_tutorial_steps(:platform_settings_api_token) %>
    <% end %>
  </div>
</div>
