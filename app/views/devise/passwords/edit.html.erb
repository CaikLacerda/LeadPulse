<%# app/views/devise/passwords/edit.html.erb %>

<div class="auth-shell auth-shell--register flex min-h-[calc(100vh-4rem)] flex-col-reverse md:min-h-screen md:flex-row">
  <div class="auth-card flex-1 overflow-y-auto bg-white px-5 pb-10 pt-8 sm:px-8 md:flex md:items-start md:justify-center md:px-16 md:pt-12">
    <div class="auth-card-bolts">
      <div class="home-bolt left-[10%] top-[11%] hidden h-24 w-14 md:block"></div>
      <div class="home-bolt home-bolt--soft right-[10%] top-[18%] hidden h-20 w-12 md:block"></div>
      <div class="home-bolt right-[16%] bottom-[18%] hidden h-28 w-16 md:block"></div>
      <div class="home-bolt home-bolt--soft left-[18%] bottom-[10%] hidden h-20 w-12 md:block"></div>
    </div>

    <div class="mx-auto w-full max-w-md">
      <%= link_to "← Voltar para login", new_session_path(resource_name),
          class: "mb-8 inline-block text-sm font-semibold text-blue-600 hover:underline" %>

      <h2 class="mb-1 mt-4 text-3xl font-black text-gray-900">Definir nova senha</h2>
      <p class="mb-7 text-sm text-gray-500">Escolha uma nova senha para voltar ao painel com segurança.</p>

      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">
          <% resource.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% elsif alert %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600"><%= alert %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div class="mb-4">
          <%= f.label :password, "Nova senha", class: "mb-1.5 block text-sm font-semibold text-gray-800" %>
          <%= f.password_field :password,
              autofocus: true,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" %>
          <% if @minimum_password_length %>
            <p class="mt-2 text-xs text-gray-400">Use pelo menos <%= @minimum_password_length %> caracteres.</p>
          <% end %>
        </div>

        <div class="mb-6">
          <%= f.label :password_confirmation, "Confirmar nova senha", class: "mb-1.5 block text-sm font-semibold text-gray-800" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "••••••••",
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-orange-500" %>
        </div>

        <%= f.submit "Salvar nova senha",
            class: "w-full cursor-pointer rounded-xl bg-orange-500 py-4 text-sm font-bold text-white shadow-lg shadow-orange-200 transition-all hover:-translate-y-0.5 hover:bg-orange-600" %>
      <% end %>
    </div>
  </div>

  <div class="auth-copy auth-banner relative hidden w-1/2 flex-col justify-center overflow-hidden bg-orange-500 p-14 md:flex">
    <div class="auth-orb auth-orb--slow absolute -bottom-32 -right-32 h-96 w-96 rounded-full bg-orange-400 opacity-40"></div>
    <div class="auth-orb auth-orb--delay auth-orb--reverse absolute -left-24 -top-24 h-72 w-72 rounded-full bg-orange-600 opacity-30"></div>

    <div class="z-10">
      <p class="mb-6 text-xs font-bold uppercase tracking-widest text-blue-900">Redefinição de senha</p>
      <h1 class="text-7xl font-black leading-none text-white">VOLTE</h1>
      <h1 class="mb-8 text-7xl font-black leading-none text-blue-800">COM TUDO.</h1>
      <p class="mb-10 max-w-sm text-lg leading-relaxed text-orange-100">
        Atualize sua senha e recupere o acesso para continuar validando lotes, ajustando integrações e acompanhando a operação.
      </p>

      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-800">
            <span class="text-xs text-white">✓</span>
          </div>
          <p class="font-semibold text-white">Atualização segura da sua conta</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-800">
            <span class="text-xs text-white">✓</span>
          </div>
          <p class="font-semibold text-white">Acesso rápido de volta ao painel</p>
        </div>
      </div>
    </div>
  </div>
</div>
