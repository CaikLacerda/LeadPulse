<%# app/views/devise/passwords/new.html.erb %>

<div class="auth-shell auth-shell--login flex min-h-[calc(100vh-4rem)] flex-col md:min-h-screen md:flex-row">
  <div class="auth-copy auth-banner hidden w-1/2 flex-col justify-between overflow-hidden bg-blue-600 p-14 md:flex">
    <div class="auth-orb auth-orb--slow absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-blue-500 opacity-40"></div>
    <div class="auth-orb auth-orb--delay auth-orb--reverse absolute -right-24 -top-24 h-72 w-72 rounded-full bg-blue-700 opacity-30"></div>

    <a href="/" class="z-10 flex items-center gap-2 text-xl font-extrabold text-white"></a>

    <div class="z-10">
      <p class="mb-6 text-xs font-bold uppercase tracking-[0.28em] text-blue-100">Recuperação de acesso</p>
      <h1 class="text-6xl font-black leading-none text-white">VOLTE A</h1>
      <h1 class="mb-8 text-6xl font-black leading-none text-orange-500">OPERAR.</h1>
      <p class="max-w-sm text-lg leading-relaxed text-blue-100">
        Informe seu e-mail e enviaremos um link para redefinir a senha com segurança e retomar o acesso ao LeadPulse.
      </p>

      <div class="mt-10 flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-white/15 text-sm font-bold text-white">✓</div>
          <p class="font-semibold text-white">Link seguro para redefinição de senha</p>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-white/15 text-sm font-bold text-white">✓</div>
          <p class="font-semibold text-white">Retorno rápido para sua operação</p>
        </div>
      </div>
    </div>

    <div class="z-10"></div>
  </div>

  <div class="auth-card flex-1 bg-white px-5 py-10 sm:px-8 md:flex md:items-center md:justify-center md:px-20">
    <div class="auth-card-bolts">
      <div class="home-bolt left-[12%] top-[13%] hidden h-24 w-14 md:block"></div>
      <div class="home-bolt home-bolt--soft right-[14%] top-[22%] hidden h-20 w-12 md:block"></div>
      <div class="home-bolt right-[10%] bottom-[18%] hidden h-28 w-16 md:block"></div>
      <div class="home-bolt home-bolt--soft left-[20%] bottom-[12%] hidden h-20 w-12 md:block"></div>
    </div>

    <div class="mx-auto w-full max-w-md">
      <%= link_to "← Voltar para login", new_session_path(resource_name),
          class: "mb-8 inline-block text-sm font-semibold text-blue-600 hover:underline" %>

      <h2 class="mb-1 text-4xl font-black text-gray-900">Esqueceu sua senha?</h2>
      <p class="mb-8 text-base text-gray-500">Digite o e-mail da sua conta para receber o link de redefinição.</p>

      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">
          <% resource.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% elsif alert %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600"><%= alert %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <div class="mb-6">
          <%= f.label :email, "E-mail corporativo", class: "mb-1.5 block text-sm font-semibold text-gray-800" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "voce@empresa.com",
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 transition-all focus:border-transparent focus:outline-none focus:ring-2 focus:ring-blue-500" %>
        </div>

        <%= f.submit "Enviar instruções de redefinição",
            class: "w-full cursor-pointer rounded-xl bg-blue-600 py-4 text-sm font-bold text-white shadow-lg shadow-blue-200 transition-all hover:-translate-y-0.5 hover:bg-blue-700" %>
      <% end %>

      <p class="mt-8 text-center text-sm text-gray-500">
        Lembrou sua senha?
        <%= link_to "Voltar para o login", new_session_path(resource_name), class: "font-bold text-orange-500 hover:underline" %>
      </p>
    </div>
  </div>
</div>
